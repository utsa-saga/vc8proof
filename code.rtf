\par 
\par \hich\af44\dbch\af31505\loch\f44 int main(int argc, char *argv[])\{
\par \hich\af44\dbch\af31505\loch\f44     ifstream viewPointInput;
\par \hich\af44\dbch\af31505\loch\f44     viewPointInput.open("v\hich\af44\dbch\af31505\loch\f44 plist.txt");
\par 
\par \hich\af44\dbch\af31505\loch\f44     // read vplist.txt into viewpointsAH vector
\par \hich\af44\dbch\af31505\loch\f44     while(!viewPointInput.eof())\{
\par \hich\af44\dbch\af31505\loch\f44         string thisVP = "";
\par \hich\af44\dbch\af31505\loch\f44         while(viewPointInput.peek()!='\\n')
\par \hich\af44\dbch\af31505\loch\f44         \{
\par \hich\af44\dbch\af31505\loch\f44             thisVP += viewPointInput.get();
\par \hich\af44\dbch\af31505\loch\f44         \}
\par \hich\af44\dbch\af31505\loch\f44         viewPointInput.ge\hich\af44\dbch\af31505\loch\f44 t();
\par \hich\af44\dbch\af31505\loch\f44         viewpointsAH.push_back(thisVP);
\par \hich\af44\dbch\af31505\loch\f44         viewPointInput.peek();
\par \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44     viewPointInput.close();
\par \hich\af44\dbch\af31505\loch\f44     
\par \hich\af44\dbch\af31505\loch\f44     for(int i = (atoi(argv[1])); i <= 11880; i = i + 23) \{
\par \hich\af44\dbch\af31505\loch\f44         // process case by case
\par \hich\af44\dbch\af31505\loch\f44         string fileName = "../Unsolved/case" + to_string(i) + ".txt";
\par \hich\af44\dbch\af31505\loch\f44         ifstream input;
\par \hich\af44\dbch\af31505\loch\f44         input.open(fileName);
\par \hich\af44\dbch\af31505\loch\f44         
\par \hich\af44\dbch\af31505\loch\f44         vector<string> initialInput;
\par \hich\af44\dbch\af31505\loch\f44         if(input.fail())\{
\par \hich\af44\dbch\af31505\loch\f44             // skip
\par \hich\af44\dbch\af31505\loch\f44             // cout << "Could not open "\hich\af44\dbch\af31505\loch\f44  << fileName << endl;
\par \hich\af44\dbch\af31505\loch\f44             continue;
\par \hich\af44\dbch\af31505\loch\f44         \}
\par \hich\af44\dbch\af31505\loch\f44         
\par \hich\af44\dbch\af31505\loch\f44         // read case_i.txt to initialInput vector
\par \hich\af44\dbch\af31505\loch\f44         while(!input.eof())\{
\par \hich\af44\dbch\af31505\loch\f44             string thisPoint = "";
\par \hich\af44\dbch\af31505\loch\f44             while(input.peek()!='\\n')
\par \hich\af44\dbch\af31505\loch\f44                 thisPoint += input.get();
\par \hich\af44\dbch\af31505\loch\f44             input.get();
\par \hich\af44\dbch\af31505\loch\f44             initialInput.push_back(thisPoint);
\par \hich\af44\dbch\af31505\loch\f44             input.peek();
\par \hich\af44\dbch\af31505\loch\f44         \}
\par \hich\af44\dbch\af31505\loch\f44         input.close();
\par \hich\af44\dbch\af31505\loch\f44         
\par \hich\af44\dbch\af31505\loch\f44         time_t start,end;
\par \hich\af44\dbch\af31505\loch\f44         time(&start);
\par 
\par \hich\af44\dbch\af31505\loch\f44         if(!candidateOrderingIsExtendable(initialInput,i))\{
\par \hich\af44\dbch\af31505\loch\f44             time(&end);
\par \hich\af44\dbch\af31505\loch\f44             double runningTime = double(end - start);
\par \hich\af44\dbch\af31505\loch\f44             cout << "Case " << i << " couldn't fit all " << viewpointsAH.size() << " points.  Running Time: " << setpr\hich\af44\dbch\af31505\loch\f44 ecision(2) << runningTime << " seconds." << endl;
\par \hich\af44\dbch\af31505\loch\f44             string mvString = "mv " + fileName + " ../Orange256/";
\par \hich\af44\dbch\af31505\loch\f44             if(system(mvString.c_str()))\{
\par \hich\af44\dbch\af31505\loch\f44                 cout << "Couldn't move file" << endl;
\par \hich\af44\dbch\af31505\loch\f44                 return -1;
\par \hich\af44\dbch\af31505\loch\f44             \}
\par \hich\af44\dbch\af31505\loch\f44   \hich\af44\dbch\af31505\loch\f44       \}
\par \hich\af44\dbch\af31505\loch\f44         else\{
\par \hich\af44\dbch\af31505\loch\f44             time(&end);
\par \hich\af44\dbch\af31505\loch\f44             double runningTime = double(end - start);
\par \hich\af44\dbch\af31505\loch\f44             cout << "Case " << i << " placed all " << viewpointsAH.size() << " points.  RT: " << setprecision(2) << runningTime << " seconds." << endl;
\par \hich\af44\dbch\af31505\loch\f44     \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44     \}
