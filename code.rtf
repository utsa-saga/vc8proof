\par \tab \hich\af44\dbch\af31505\loch\f44 return 0;
\par \}
\par 
\par 
\par \hich\af44\dbch\af31505\loch\f44 //Return true if everything is placed.  Return false if not everything is placed.
\par \hich\af44\dbch\af31505\loch\f44 bool candidateOrderingIsExtendable(vector<string> inputPoints,int caseNumber)\{ 
\par \hich\af44\dbch\af31505\loch\f44     unordered_map<string,bool> usedVP;
\par \hich\af44\dbch\af31505\loch\f44     
\par \hich\af44\dbch\af31505\loch\f44     for(int i=0; i\hich\af44\dbch\af31505\loch\f44 <inputPoints.size(); i++)\{
\par \hich\af44\dbch\af31505\loch\f44         if(inputPoints[i].size() > 1)
\par \hich\af44\dbch\af31505\loch\f44         \{
\par \hich\af44\dbch\af31505\loch\f44             // remove the viewpoints in inputPoints vector (mark them as used), we a\hich\af44\dbch\af31505\loch\f44 lways try to recursively insert unused viewpoints from viewpointsAH
\par \hich\af44\dbch\af31505\loch\f44             usedVP[inputPoints[i]] = true;
\par \hich\af44\dbch\af31505\loch\f44         \}
\par \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44     
\par \hich\af44\dbch\af31505\loch\f44     vector<string> viewPointList;
\par \hich\af44\dbch\af31505\loch\f44     for(int i=0; i<viewpointsAH.size(); i++)\{
\par \hich\af44\dbch\af31505\loch\f44         if(!usedVP[viewpointsAH[i]])
\par \hich\af44\dbch\af31505\loch\f44        \hich\af44\dbch\af31505\loch\f44      viewPointList.push_back(viewpointsAH[i]);
\par \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44         
\par \hich\af44\dbch\af31505\loch\f44     if(viewPointList.size() == 0)\{
\par \hich\af44\dbch\af31505\loch\f44         // no more unused viewpoint to insert
\par \hich\af44\dbch\af31505\loch\f44         cout << "We placed everything!" << endl;
\par \hich\af44\dbch\af31505\loch\f44         isNotRealizable(&inputPoints,caseNumber);
\par \hich\af44\dbch\af31505\loch\f44         // isN\hich\af44\dbch\af31505\loch\f44 otRealizable(&inputPoints)   
\par \hich\af44\dbch\af31505\loch\f44         return true;
\par \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44     
\par \hich\af44\dbch\af31505\loch\f44     // always pick the viewpoint that has minimum gap could make current ordering feasible
\par \hich\af44\dbch\af31505\loch\f44     int minGaps = inputPoints.size() + 2;
\par \hich\af44\dbch\af31505\loch\f44     string optVP;
\par \hich\af44\dbch\af31505\loch\f44     vector<int> optimalGaps;
\par \hich\af44\dbch\af31505\loch\f44     
\par \hich\af44\dbch\af31505\loch\f44     for(i\hich\af44\dbch\af31505\loch\f44 nt z=0; z < viewPointList.size(); z++)\{
\par \hich\af44\dbch\af31505\loch\f44         // check every unused viewpoints in viewPointList
\par \hich\af44\dbch\af31505\loch\f44         int correctGaps = 0;
\par \hich\af44\dbch\af31505\loch\f44         vector<int> feasibleGaps;
\par \hich\af44\dbch\af31505\loch\f44         
\par \hich\af44\dbch\af31505\loch\f44         for(int gap = 0; (gap <= inputPoin\hich\af44\dbch\af31505\loch\f44 ts.size()) && (correctGaps < minGaps); gap++)\{
\par \hich\af44\dbch\af31505\loch\f44             vector<string> currentPoints;
\par \hich\af44\dbch\af31505\loch\f44             int index = 0;
\par \hich\af44\dbch\af31505\loch\f44             
\par \hich\af44\dbch\af31505\loch\f44             // insert this viewpoint into currentPoints in every position
\par \hich\af44\dbch\af31505\loch\f44             while(index < gap)\{
\par \hich\af44\dbch\af31505\loch\f44                 curre\hich\af44\dbch\af31505\loch\f44 ntPoints.push_back(inputPoints[index]);
\par \hich\af44\dbch\af31505\loch\f44                 index++;
\par \hich\af44\dbch\af31505\loch\f44             \}
\par \hich\af44\dbch\af31505\loch\f44             currentPoints.push_back(viewPointList[z]);
\par \hich\af44\dbch\af31505\loch\f44             while(index<inputPoints.size())\{
\par \hich\af44\dbch\af31505\loch\f44                 currentPoints.push_back(inputPoints[index]);
\par \hich\af44\dbch\af31505\loch\f44                 \hich\af44\dbch\af31505\loch\f44 index++;
\par \hich\af44\dbch\af31505\loch\f44             \}
\par \hich\af44\dbch\af31505\loch\f44             
\par \hich\af44\dbch\af31505\loch\f44             // intermediate checking, store the number of gaps and which gaps are feasible
\par \hich\af44\dbch\af31505\loch\f44             if(!isNotRealizable(&currentPoints, 0))\{
\par \hich\af44\dbch\af31505\loch\f44                 correctGaps++;
\par \hich\af44\dbch\af31505\loch\f44                 feasibleGaps.push_back(gap);
\par \hich\af44\dbch\af31505\loch\f44             \}
\par \hich\af44\dbch\af31505\loch\f44         \}
\par \hich\af44\dbch\af31505\loch\f44         
\par \hich\af44\dbch\af31505\loch\f44         // find the optimal one that has the minimum number of gaps could make current ordering feasible
\par \hich\af44\dbch\af31505\loch\f44         if(correctGaps<minGaps)\{
\par \hich\af44\dbch\af31505\loch\f44             minGaps = correctGaps;
\par \hich\af44\dbch\af31505\loch\f44             optVP = viewPointList[z];
\par \hich\af44\dbch\af31505\loch\f44             optimalGaps = feasibleGaps;
\par \hich\af44\dbch\af31505\loch\f44         \}
\par \hich\af44\dbch\af31505\loch\f44         
\par \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44       
\par \hich\af44\dbch\af31505\loch\f44     if(minGaps == 0)\{
\par \hich\af44\dbch\af31505\loch\f44         // Found a point that cannot go into the previous config.
\par \hich\af44\dbch\af31505\loch\f44         // cout << "Couldn't place " << optVP << endl;
\par \hich\af44\dbch\af31505\loch\f44         return false;
\par \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44     
\par \hich\af44\dbch\af31505\loch\f44     else\{
\par \hich\af44\dbch\af31505\loch\f44         // recursively call candidateOrderingIsExtendable with this new added optimal viewpoint in every gaps, not only the feasible gaps
\par \hich\af44\dbch\af31505\loch\f44         for(int i=0; i<optimalGaps.size(); i++)\{
\par \hich\af44\dbch\af31505\loch\f44             
\par \hich\af44\dbch\af31505\loch\f44             int gap = optimalGaps[i];
\par \hich\af44\dbch\af31505\loch\f44             vect\hich\af44\dbch\af31505\loch\f44 or<string> nextInput;
\par \hich\af44\dbch\af31505\loch\f44      
\par \hich\af44\dbch\af31505\loch\f44             int index = 0;
\par \hich\af44\dbch\af31505\loch\f44             while(index < gap)\{
\par \hich\af44\dbch\af31505\loch\f44                 nextInput.push_back(inputPoints[index]);
\par \hich\af44\dbch\af31505\loch\f44                 index++;
\par \hich\af44\dbch\af31505\loch\f44             \}
\par \hich\af44\dbch\af31505\loch\f44             nextInput.push_back(optVP);
\par \hich\af44\dbch\af31505\loch\f44             while(index<inputPoin\hich\af44\dbch\af31505\loch\f44 ts.size())\{
\par \hich\af44\dbch\af31505\loch\f44                 nextInput.push_back(inputPoints[index]);
\par \hich\af44\dbch\af31505\loch\f44                 index++;
\par \hich\af44\dbch\af31505\loch\f44             \}
\par \hich\af44\dbch\af31505\loch\f44             
\par \hich\af44\dbch\af31505\loch\f44             if(candidateOrderingIsExtendable(nextInput,caseNumber))
\par \hich\af44\dbch\af31505\loch\f44             \{
\par \hich\af44\dbch\af31505\loch\f44                 return true;
\par \hich\af44\dbch\af31505\loch\f44             \}
\par \hich\af44\dbch\af31505\loch\f44         \}
\par \hich\af44\dbch\af31505\loch\f44     \}
\par \hich\af44\dbch\af31505\loch\f44     return false;
\par \}
\par 
\par \hich\af44\dbch\af31505\loch\f44 bool isNotRealizable(vector<string> *currentPoints, int caseNumber)\{
\par \hich\af44\dbch\af31505\loch\f44     ofstream output;
\par \hich\af44\dbch\af31505\loch\f44     if(caseNumber != 0)\{
